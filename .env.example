# Copy this file to .env and fill your values

# Required: Groq API key for LLM generation
GROQ_API_KEY=your_groq_api_key_here

# Optional: Groq model override (default in app: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Tavily API key for live web resource recommendations in skill-gap plans
TAVILY_API_KEY=your_tavily_api_key_here
